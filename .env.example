# Configurações do qBittorrent (suporta uma ou múltiplas instâncias)
# Para uma instância: coloque apenas um valor
# Para múltiplas: separe os valores por vírgula (na mesma ordem)

# Nomes das instâncias
QB_NAMES=default
# URLs das instâncias
QB_URLS=http://192.168.1.30:8181
# Usuários (opcional, padrão: admin)
QB_USERS=admin
# Senhas (opcional, padrão: adminadmin)
QB_PASSWORDS=sua_senha_aqui
# Caminhos de armazenamento (opcional, padrão: /)
QB_STORAGE_PATHS=/
# Prioridades (opcional, padrão: 0, maior = mais prioritário)
QB_PRIORITIES=0
# Intervalo de verificação em segundos
INTERVALO=120

# Exemplo com múltiplas instâncias (descomente e ajuste):
# QB_NAMES=servidor-principal,servidor-backup,servidor-local
# QB_URLS=http://192.168.1.10:8080,http://192.168.1.20:8080,http://localhost:8080
# QB_USERS=admin,admin,admin
# QB_PASSWORDS=senha123,senha456,adminpass
# QB_STORAGE_PATHS=/downloads,/data,/torrents
# QB_PRIORITIES=10,5,0

# Token do Bot do Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ
TELEGRAM_CHAT_ID=-1234567890

# Usuários autorizados (separados por vírgula)
# Para obter seu ID, envie uma mensagem para @userinfobot
AUTHORIZED_USERS=123456789,987654321

# Configurações do Jellyfin
JELLYFIN_URL=http://192.168.1.30:8097
JELLYFIN_USERNAME=seu_usuario
JELLYFIN_PASSWORD=sua_senha
JELLYFIN_API_KEY = "sua_api_key_aqui"

# Tempo de expiração das mensagens de status (em segundos)
EXPIRAR_MSG=30

# CONFIGURAÇÕES DE DOWNLOAD
# Define se os arquivos baixados devem ser removidos após o envio (True/False)
REMOVE_AFTER_SEND=False

# NOTIFICAÇÕES DO JELLYFIN
# Habilita/desabilita notificações automáticas de novos conteúdos (True/False)
JELLYFIN_NOTIFICATIONS_ENABLED=True
# Intervalo em segundos para verificar novos conteúdos (padrão: 1800 = 30 min)
JELLYFIN_NOTIFICATION_INTERVAL=1800

# CONFIGURAÇÕES DO WHATSAPP (WAHA)
# URL da API WAHA (use http://waha:3000 dentro do Docker)
WAHA_URL=http://waha:3000
# Chave de API para autenticação
WAHA_API_KEY=local-dev-key-123
# Nome da sessão WhatsApp
WAHA_SESSION=default
# Números autorizados a usar o bot (separados por vírgula, com código do país)
# Exemplo: 5511999999999,5511888888888
AUTHORIZED_WHATSAPP_NUMBERS=
# ID do grupo autorizado (opcional, deixe vazio para aceitar apenas mensagens diretas)
# Exemplo: 5511999999999-1234567890@g.us
AUTHORIZED_WHATSAPP_GROUP=
# Credenciais do Dashboard WAHA (acesse em http://localhost:3000/dashboard)
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin123
# Credenciais do Swagger WAHA (acesse em http://localhost:3000/)
WAHA_SWAGGER_USERNAME=admin
WAHA_SWAGGER_PASSWORD=swagger123

# CONFIGURAÇÕES DE SINCRONIZAÇÃO (v0.0.1.7-alpha)
# Intervalo em segundos para verificar torrents concluídos (padrão: 30)
SYNC_INTERVAL=30
# Habilita/desabilita atualização automática da biblioteca Jellyfin (True/False)
AUTO_SCAN_JELLYFIN=True